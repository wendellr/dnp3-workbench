APP_ENV=production
APP_VERSION=1.0.0
DNP3_ENGINE=native_opendnp3
DNP3_MASTER_RUNTIME_BUILD_ENABLE_OPENDNP3=ON
DNP3_MASTER_RUNTIME_BASE_URL=http://dnp3-master-runtime:21200

# Public production posture: masters are available; public outstation management is blocked.
ENABLE_DEMO_OUTSTATION=true
ENABLE_PUBLIC_OUTSTATION_MANAGEMENT=false

# Use JSON list syntax for pydantic-settings.
CORS_ORIGINS=["https://dnp3.ioda.com.br"]

# Port exposed to the host. Point your server Nginx upstream to this port.
FRONTEND_HTTP_PORT=8080

